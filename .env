# ============================================
# 交通标志识别系统（RT-DETR）环境配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# --------------------------------------------
# 模型配置
# --------------------------------------------
# 模型类型: yolo / rtdetr / auto（auto 根据文件名自动判断）
MODEL_TYPE=yolo

# 权重路径（rtdetr 训练的 best.pt）
# WEIGHTS_PATH=runs/train/exp/weights/best.pt

# 权重路径（yolo 训练的 best.pt）
WEIGHTS_PATH=runs/train/exp_yolov8/weights/best.pt

# ↓ 如需切换到官方 RT-DETR 预训练权重（可识别 COCO 80 类），改为：
# MODEL_TYPE=rtdetr
# WEIGHTS_PATH=rtdetr-l.pt

# --------------------------------------------
# 文件存储配置
# --------------------------------------------
UPLOAD_FOLDER=web/static/uploads
RESULT_FOLDER=web/static/results

# --------------------------------------------
# 检测参数
# --------------------------------------------
ANOMALY_CONF_THRES=0.5
SCALE_THRESHOLD=200

# --------------------------------------------
# Flask 配置
# --------------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=False

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
